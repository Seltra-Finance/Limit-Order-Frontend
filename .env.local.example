# Copy to .env.local. Values below are the deployed Fuji demo stack
# (contracts repo: contracts/addresses.fuji.json).
NEXT_PUBLIC_CHAIN_ID=43113
NEXT_PUBLIC_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_EXPLORER_BASE_URL=https://testnet.snowtrace.io
NEXT_PUBLIC_API_REST_URL=http://localhost:8080
NEXT_PUBLIC_API_WS_URL=ws://localhost:8080/stream
NEXT_PUBLIC_SETTLEMENT=0x962F86c218eEdEbFd2AAc6cb35b5283232769848
NEXT_PUBLIC_ROUTER=0xba1f5399D6A09b73206EC9449e2ba1bA7db27257
NEXT_PUBLIC_PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3
# Token pair (must match the settlement allowlist; demo tokens are open-mint)
NEXT_PUBLIC_BASE_TOKEN=0x760D9a5B4ae94f5e6c3ce014e3C116544515C830
NEXT_PUBLIC_BASE_SYMBOL=sWAVAX
NEXT_PUBLIC_BASE_DECIMALS=18
NEXT_PUBLIC_QUOTE_TOKEN=0x00B766567013BbCe12bF802f6E7C65F6da581Efe
NEXT_PUBLIC_QUOTE_SYMBOL=sUSDC
NEXT_PUBLIC_QUOTE_DECIMALS=6
# Reown project id (dashboard.reown.com): enables the AppKit wallet modal
# (mobile/WalletConnect). Without it a basic injected-wallet dialog is used.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Public URL of the app; used for OG metadata and shown to wallets when pairing.
NEXT_PUBLIC_APP_URL=http://localhost:3000
